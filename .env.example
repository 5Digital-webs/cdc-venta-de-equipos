# Cloudflare Turnstile (contact form)
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# SMTP (contact form emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com
SMTP_TO=contact@example.com

# Optional: used in email subject (default: "Sitio")
SITE_NAME=My Site

# Google Analytics 4 (optional: set to your G-XXXXXXXXXX measurement ID to enable)
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
