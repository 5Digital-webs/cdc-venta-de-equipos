---
//src/components/CardProductos.astro
import { Image } from "astro:assets";

interface Props {
    marca: string;
    nombre: string;
    imagen: ImageMetadata | string;
    alt: string;
    backgroundColor?: 'blue' | 'green';
    href?: string;
    whatsappMessage?: string;
}

const {
    marca,
    nombre,
    imagen,
    alt,
    backgroundColor = "blue",
    href = "#",
    whatsappMessage = "Hola, me interesa este producto",
} = Astro.props;

const bgColor = backgroundColor === 'blue' ? 'bg-[#EAF9FF]' : 'bg-[#EBFFF6]';
---

<div class={`${bgColor} p-6 relative hover:shadow-lg transition-shadow duration-300`}>
    <button
        class="absolute top-4 right-4 w-10 h-10 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors shadow-sm group z-10"
        aria-label="Agregar a favoritos"
    >
        <svg class="w-5 h-5 text-gray-400 group-hover:text-red-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
        </svg>
    </button>

    <a href={href} class="block cursor-pointer">
        <div class="flex justify-center mb-6 pt-6">
            {typeof imagen === 'string' ? (
                <img src={imagen} alt={alt} class="w-full h-48 object-contain hover:scale-105 transition-transform duration-300" />
            ) : (
                <Image src={imagen} alt={alt} class="w-full h-48 object-contain hover:scale-105 transition-transform duration-300" />
            )}
        </div>

        <div class="space-y-3">
            <p class="text-sm text-left font-semibold text-gray-500 uppercase tracking-wide">
                {marca}
            </p>
            <h3 class="text-xl text-left font-bold text-gray-800 line-clamp-2 h-14 hover:text-primary transition-colors">
                {nombre}
            </h3>
        </div>
    </a>

    <a 
        href={`https://wa.me/56953281492?text=${encodeURIComponent(whatsappMessage)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="block mt-4"
    >
        <button class="w-full bg-primary text-white py-3 rounded-full font-semibold hover:bg-primary/90 transition-colors flex items-center justify-center gap-2">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"/>
                <circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            <span>Cotizar</span>
        </button>
    </a>
</div>