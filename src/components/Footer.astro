---
import { Image } from "astro:assets";
import facebook from "../assets/svg/ICONOS-03.svg";
import whatsapp from "../assets/svg/ICONOS-04.svg";
import instagram from "../assets/svg/ICONOS-04.svg";
import whatsappIcon from "../assets/svg/icono-wsp.svg";
import phoneIcon from "../assets/svg/phone.svg?raw";
import correoIcon from "../assets/svg/correo.svg?raw";
import mapaIcon from "../assets/svg/mapa.svg?raw";
//import { Icon } from "astro-icon/components";

// Footer component props
export interface Props {
  companyName?: string;
  year?: number;
}

const { companyName = "Medical Más Salud", year = new Date().getFullYear() } =
  Astro.props;
---

<footer class="bg-[#181619] text-gray-100 mt-auto">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 py-12">
      <!-- Logo + Redes Sociales -->
      <div class="flex flex-col items-center gap-9">
        <img
          src="/images/logo.png"
          alt="Medical Más Salud - Artículos Médicos"
          class="w-28 h-28"
          height="200"
          width={500}
          loading="eager"
        />
        <div class="flex flex-row justify-between items-center gap-6">
          <a href="https://www.facebook.com/medicalmasalud" target="_blank">
            <Image src={facebook} alt="Facebook" class="w-10 h-10" /></a
          >
          <a href="https://wa.me/56953281492" target="_blank">
            <Image src={whatsapp} alt="WhatsApp" class="w-10 h-10" /></a
          >
          <a href="https://www.instagram.com/medicalmasalud" target="_blank">
            <Image src={instagram} alt="Instagram" class="w-10 h-10" /></a
          >
        </div>
      </div>

      <!-- Servicios -->
      <div class="flex flex-col">
        <ul class="list-none m-0 p-0 flex flex-col gap-6">
          <li>
            <a
              href="/servicios/arriendo-de-concentradores-de-oxígeno"
              class="text-white no-underline font-medium hover:text-blue-400 transition-colors duration-200"
              >Arriendo de <br />Concentradores de Oxígeno</a
            >
          </li>
          <li>
            <a
              href="/servicios/venta-de-insumos-médicos-de-oxigenoterapia"
              class="text-white no-underline font-medium hover:text-blue-400 transition-colors duration-200"
              >Venta de <br />Concentradores de Oxígeno</a
            >
          </li>
          <li>
            <a
              href="/servicios/mantención-y-reparación-de-concentradores-de-oxígeno"
              class="text-white no-underline font-medium hover:text-blue-400 transition-colors duration-200"
              >Reparación de <br />Concentradores de Oxígeno</a
            >
          </li>
        </ul>
      </div>

      <!-- Contacto -->
      <div class="flex flex-col bg-[#212121] rounded-lg p-4">
        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-1">
            <div class="flex flex-row gap-10 items-center mb-4">
              <Image src={whatsappIcon} alt="whatsappIcon" class="w-8 h-8" />

              <div class="flex flex-col gap-1">
                <a
                  href="tel:+56953281492"
                  class="text-[#D3D3D3] no-underline hover:text-blue-400 transition-colors duration-200 text-sm font-medium"
                  >+56 9 5328 1492</a
                >
                <a
                  href="tel:+56996873952"
                  class="text-[#D3D3D3] no-underline hover:text-blue-400 transition-colors duration-200 text-sm font-medium"
                  >+56 9 9687 3952</a
                >
              </div>
            </div>

            <div class="flex flex-row gap-10 items-center mb-4">
              <div
                class="w-8 h-8 text-blue-500 fill-white"
                set:html={phoneIcon}
              />
              <a
                href="tel:+56229326779"
                class="text-[#D3D3D3] no-underline hover:text-blue-400 transition-colors duration-200 text-sm font-medium"
                >22-932 6779</a
              >
            </div>

            <div class="flex flex-row gap-10 items-center mb-4">
              <div
                class="w-8 h-8 text-blue-500 fill-white"
                set:html={correoIcon}
              />
              <div class="flex flex-col gap-1">
                <a
                  href="mailto:medicalmasalud@gmail.com"
                  class="text-[#D3D3D3] no-underline hover:text-blue-400 transition-colors duration-200 text-sm font-medium"
                  >medicalmasalud@gmail.com</a
                >
                <a
                  href="mailto:hugo-serviciotecnico@hotmail.com"
                  class="text-[#D3D3D3] no-underline hover:text-blue-400 transition-colors duration-200 text-sm font-medium"
                  >hugo-serviciotecnico@hotmail.com</a
                >
              </div>
            </div>

            <div class="flex flex-row gap-10 items-center mb-4">
              <div
                class="w-8 h-8 text-blue-500 fill-white"
                set:html={mapaIcon}
              />
              <p class="text-[#D3D3D3] m-0 text-sm">
                Av. El Conquistador 01260, Maipú
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="bg-primary py-2 w-full">
    <p class="text-black m-0 text-sm text-center">
      © {year}
      {companyName}. Todos los derechos reservados.
    </p>
  </div>
</footer>
