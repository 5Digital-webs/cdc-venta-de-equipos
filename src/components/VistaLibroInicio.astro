---
import { Image } from "astro:assets";

type ImageMetadata = import('astro').ImageMetadata;

interface Props {
    image: string | ImageMetadata;
    alt: string;
    title: string;
    description: string;
    price: string;
    author: string;
}

const { 
    image, 
    alt, 
    title, 
    description, 
    price, 
    author,
    } = Astro.props;
---

<div class="flex flex-row gap-0 p-0 rounded-lg">
    {typeof image === 'string' ? (
        <img src={image} alt={alt} width={300} height={400} />
    ) : (
        <Image src={image} alt={alt} width={300} height={400} />
    )}
    <div class="flex flex-col gap-2 w-full p-4 rounded-lg" style="background-color: #FFF9EB;">
        <h2 class="text-[30px] leading-[1.2] text-text-book font-bold">{title}</h2>
        <div>
            <p class="text-text-book text-[12px]">Autor: <span class="text-text-book text-[12px] font-bold">{author}</span></p>
        </div>
        
        <p class="text-text-book text-[15px] leading-[1.2] text-justify">{description}</p>
        <div class="flex flex-row gap-2">
            <p class="text-text-book">{price}</p>
        </div>
    </div>
</div>