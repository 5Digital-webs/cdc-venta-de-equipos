---
import { isInputError } from "astro:actions";

interface Props {
  actionPath: string;
  result?: { data?: { message?: string }; error?: { message?: string; fields?: Record<string, string[]> } };
  inputErrors?: Record<string, string[]>;
  siteKey?: string;
}

const { actionPath, result, inputErrors = {}, siteKey } = Astro.props;
const fieldIds = ["nombre", "email", "telefono", "empresa", "producto", "mensaje"] as const;
---

<div id="contactFormFeedback" class="mb-6" role="alert">
  {result && !result.error && (
    <div id="contactSuccessMessage" class="p-3 bg-green-100 border border-green-400 text-green-700 rounded-lg">
      <span>{result.data?.message ?? "Tu mensaje ha sido enviado correctamente. Te responderemos pronto."}</span>
    </div>
  )}
  {result?.error && !isInputError(result.error) && (
    <div id="contactErrorMessage" class="p-3 bg-red-100 border border-red-400 text-red-700 rounded-lg">
      <span>{result.error.message}</span>
    </div>
  )}
</div>

<form
  id="contactForm"
  method="POST"
  action={actionPath}
  class="space-y-6"
  data-site-key={siteKey ?? undefined}
>
  <input type="hidden" name="turnstile_token" id="turnstile_token" value="" />
  <div id="turnstile-widget" class="flex justify-center my-4"></div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">Nombre *</label>
      <input
        type="text"
        id="nombre"
        name="nombre"
        required
        placeholder="Tu nombre"
        class={`w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition ${inputErrors.nombre ? "border-red-500" : "border-gray-300"}`}
        aria-describedby={inputErrors.nombre ? "error-nombre" : undefined}
      />
      <p id="error-nombre" class={`text-sm text-red-600 mt-1 ${!inputErrors.nombre?.length ? "hidden" : ""}`} aria-live="polite">
        {inputErrors.nombre?.join(", ")}
      </p>
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email *</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="tu@email.com"
        class={`w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition ${inputErrors.email ? "border-red-500" : "border-gray-300"}`}
        aria-describedby={inputErrors.email ? "error-email" : undefined}
      />
      <p id="error-email" class={`text-sm text-red-600 mt-1 ${!inputErrors.email?.length ? "hidden" : ""}`} aria-live="polite">
        {inputErrors.email?.join(", ")}
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label for="telefono" class="block text-sm font-medium text-gray-700 mb-2">Teléfono</label>
      <input
        type="tel"
        id="telefono"
        name="telefono"
        placeholder="+56 9 1234 5678"
        class={`w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition ${inputErrors.telefono ? "border-red-500" : "border-gray-300"}`}
        aria-describedby={inputErrors.telefono ? "error-telefono" : undefined}
      />
      <p id="error-telefono" class={`text-sm text-red-600 mt-1 ${!inputErrors.telefono?.length ? "hidden" : ""}`} aria-live="polite">
        {inputErrors.telefono?.join(", ")}
      </p>
    </div>
    <div>
      <label for="empresa" class="block text-sm font-medium text-gray-700 mb-2">Empresa</label>
      <input
        type="text"
        id="empresa"
        name="empresa"
        placeholder="Nombre de tu empresa"
        class={`w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition ${inputErrors.empresa ? "border-red-500" : "border-gray-300"}`}
        aria-describedby={inputErrors.empresa ? "error-empresa" : undefined}
      />
      <p id="error-empresa" class={`text-sm text-red-600 mt-1 ${!inputErrors.empresa?.length ? "hidden" : ""}`} aria-live="polite">
        {inputErrors.empresa?.join(", ")}
      </p>
    </div>
  </div>

  <div>
    <label for="producto" class="block text-sm font-medium text-gray-700 mb-2">Producto de Interés *</label>
    <select
      id="producto"
      name="producto"
      required
      class={`w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition ${inputErrors.producto ? "border-red-500" : "border-gray-300"}`}
      aria-describedby={inputErrors.producto ? "error-producto" : undefined}
    >
      <option value="">Selecciona un producto</option>
      <option value="minicargador">Minicargador</option>
      <option value="miniexcavadora">Miniexcavadora</option>
      <option value="aditamento">Aditamento</option>
      <option value="grua-horquilla">Grúa Horquilla</option>
      <option value="otro">Otro</option>
    </select>
    <p id="error-producto" class={`text-sm text-red-600 mt-1 ${!inputErrors.producto?.length ? "hidden" : ""}`} aria-live="polite">
      {inputErrors.producto?.join(", ")}
    </p>
  </div>

  <div>
    <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-2">Mensaje *</label>
    <textarea
      id="mensaje"
      name="mensaje"
      rows="5"
      required
      placeholder="Cuéntanos sobre tu proyecto y requerimientos..."
      class={`w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition resize-none ${inputErrors.mensaje ? "border-red-500" : "border-gray-300"}`}
      aria-describedby={inputErrors.mensaje ? "error-mensaje" : undefined}
    ></textarea>
    <p id="error-mensaje" class={`text-sm text-red-600 mt-1 ${!inputErrors.mensaje?.length ? "hidden" : ""}`} aria-live="polite">
      {inputErrors.mensaje?.join(", ")}
    </p>
  </div>

  <button
    type="submit"
    id="contactSubmitBtn"
    class="w-full bg-primary hover:opacity-90 text-primary-foreground font-bold py-4 px-8 rounded-lg transition transform hover:scale-[1.02] shadow-lg"
  >
    Enviar Cotización
  </button>
</form>

<script>
  import { actions, isInputError } from "astro:actions";

  const form = document.getElementById("contactForm") as HTMLFormElement | null;
  const tokenInput = document.getElementById("turnstile_token") as HTMLInputElement | null;
  const feedbackEl = document.getElementById("contactFormFeedback");

  const fieldIds = ["nombre", "email", "telefono", "empresa", "producto", "mensaje"] as const;

  function showResult(result: { data?: { message?: string }; error?: { message?: string; fields?: Record<string, string[]> } }) {
    if (!feedbackEl) return;

    const existingSuccess = feedbackEl.querySelector("#contactSuccessMessage");
    const existingError = feedbackEl.querySelector("#contactErrorMessage");
    existingSuccess?.remove();
    existingError?.remove();

    fieldIds.forEach((name) => {
      const p = document.getElementById(`error-${name}`);
      const input = document.querySelector(`[name="${name}"]`) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
      if (p) {
        p.textContent = "";
        p.classList.add("hidden");
      }
      if (input) input.classList.remove("border-red-500");
    });

    if (result.data) {
      const div = document.createElement("div");
      div.id = "contactSuccessMessage";
      div.className = "p-3 bg-green-100 border border-green-400 text-green-700 rounded-lg";
      div.setAttribute("role", "alert");
      div.textContent = result.data.message ?? "Tu mensaje ha sido enviado correctamente. Te responderemos pronto.";
      feedbackEl.prepend(div);
      feedbackEl.scrollIntoView({ behavior: "smooth", block: "nearest" });
      form?.reset();
      if (tokenInput) tokenInput.value = "";
      return;
    }

    if (result.error) {
      const div = document.createElement("div");
      div.id = "contactErrorMessage";
      div.className = "p-3 bg-red-100 border border-red-400 text-red-700 rounded-lg";
      div.setAttribute("role", "alert");
      div.textContent = result.error.message ?? "Ha ocurrido un error. Por favor, intenta de nuevo.";
      feedbackEl.prepend(div);
      feedbackEl.scrollIntoView({ behavior: "smooth", block: "nearest" });

      if (isInputError(result.error) && result.error.fields) {
        (Object.entries(result.error.fields) as [string, string[]][]).forEach(([name, messages]) => {
          const p = document.getElementById(`error-${name}`);
          const input = document.querySelector(`[name="${name}"]`) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
          if (p && messages?.length) {
            p.textContent = messages.join(", ");
            p.classList.remove("hidden");
          }
          if (input) input.classList.add("border-red-500");
        });
      }
    }
  }

  // Initialize Turnstile widget
  const siteKey = form?.dataset.siteKey;
  let turnstileWidgetId: string | null = null;

  function initTurnstile() {
    if (!siteKey || typeof window === "undefined") return;
    
    const widgetContainer = document.getElementById("turnstile-widget");
    if (!widgetContainer) return;

    const turnstile = (window as any).turnstile;
    if (!turnstile) {
      // Wait for script to load
      setTimeout(initTurnstile, 100);
      return;
    }

    turnstileWidgetId = turnstile.render(widgetContainer, {
      sitekey: siteKey,
      callback: (token: string) => {
        if (tokenInput) {
          tokenInput.value = token;
        }
      },
      "error-callback": () => {
        if (tokenInput) {
          tokenInput.value = "";
        }
      },
      "expired-callback": () => {
        if (tokenInput) {
          tokenInput.value = "";
        }
      },
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTurnstile);
  } else {
    initTurnstile();
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!tokenInput || !form) return;

    // Check if Turnstile token is present
    if (siteKey && !tokenInput.value) {
      showResult({
        error: {
          message: "Por favor, completa la verificación de seguridad.",
        },
      });
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.setAttribute("aria-busy", "true");
    }

    const { data, error } = await actions.sendContactEmail(new FormData(form));
    showResult({ data, error });

    // Reset Turnstile widget after submission
    if (turnstileWidgetId !== null && typeof window !== "undefined" && (window as any).turnstile) {
      (window as any).turnstile.reset(turnstileWidgetId);
    }
    if (tokenInput) {
      tokenInput.value = "";
    }

    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.removeAttribute("aria-busy");
    }
  });
</script>
