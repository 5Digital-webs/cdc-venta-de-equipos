---
import Layout from "@/layouts/Layout.astro";
import bannerEquipos from "@/assets/images/images-equipos/banner-equipos.jpg";
import iconoCheckServicio from "@/assets/svg/icono-check-servicio.svg";
---

<Layout
  title="Lavanderías autoservicio  | CDC Venta de Equipos"
  description="Conoce nuestros servicios."
>
  <section class="servicio-banner relative w-full ">
    <div class="relative w-full overflow-hidden">
      <img
        src={bannerEquipos.src ?? bannerEquipos}
        alt="Proyectos integrales de lavandería industrial"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
      />

      <div
        class="servicio-banner__overlay absolute inset-0"
        aria-hidden="true"
      ></div>

      <div class="relative max-w-7xl mx-auto px-4 py-12 md:py-16">
        <div class="max-w-xl">
          <span class="inline-flex items-center bg-white/15 text-white text-xs font-semibold px-4 py-2 rounded-full">
            LAVANDERÍAS AUTOSERVICIO
          </span>

          <h1 class="mt-5 text-white text-3xl md:text-4xl font-bold leading-tight">
            Soluciones de lavandería
            <br />
            autoservicio para comunidades
          </h1>

          <p class="mt-5 text-white/90 text-sm md:text-base leading-relaxed max-w-lg">
            Diseñamos e implementamos lavanderías autoservicio eficientes, robustas y adaptadas a edificios residenciales y multifamily.
          </p>

          <a
            href="#"
            class="inline-flex items-center gap-2 mt-7 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-[10px] transition-all duration-300"
          >
            Solicitar asesoría
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="servicio-estadisticas bg-[#122640] py-6">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center text-white">
       
        <div>
          <p
            class="text-4xl md:text-5xl font-bold leading-none"
            data-counter
            data-target="24"
            data-suffix="/7"
          >
            0/7
          </p>
          <p class="mt-2 text-base md:text-[20px] font-semibold">Operación continua</p>
        </div>

        <div>
          <p
            class="text-4xl md:text-5xl font-bold leading-none"
            data-counter
            data-target="0"
          >
            +0
          </p>
          <p class="mt-2 text-base md:text-[20px] font-semibold">Inversión del edificio</p>
        </div>

        <div>
          <p
            class="text-4xl md:text-5xl font-bold leading-none"
            data-counter
            data-target="100"
            data-suffix="%"
          >
            0%
          </p>
          <p class="mt-2 text-base md:text-[20px] font-semibold">Mantención incluida</p>
        </div>

       <div>
          <p
            class="text-4xl md:text-5xl font-bold leading-none"
           
          >
            +
          </p>
          <p class="mt-2 text-base md:text-[20px] font-semibold">Valor al edificio</p>
        </div>
      </div>
    </div>
  </section>

  <section class="servicio-incluye bg-[#fff] py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-center text-[#1b1e4b] text-[24px] font-[900] mb-10">
        Qué ofrecemos
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5">
        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[40px] h-[40px]" loading="lazy" />
          </div>

          <p class="font-[500] text-black text-[16px] leading-[1.15]">
            Equipamiento completo de lavadoras y secadoras
          </p>

        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[40px] h-[40px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[16px] leading-[1.15]">
            Sistemas de pago y control de acceso
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[40px] h-[40px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[16px] leading-[1.15]">
            Configuración compacta y optimización de espacio
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[40px] h-[40px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[16px] leading-[1.15]">
            Instalación y puesta en marcha 
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
           <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[40px] h-[40px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[16px] leading-[1.15]">
             Mantención continua
          </p>
        </div>

        
      </div>
    </div>
  </section>

  <section class="servicio-incluye bg-[#fff] py-6">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-center text-[#1b1e4b] text-[24px] font-[900] mb-10">
        Beneficios para la comunidad
      </h2>
     

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5">
        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[40px] h-[40px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[16px] leading-[1.15]">
             Equipos confiables y de uso intensivo 
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
           <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[40px] h-[40px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[16px] leading-[1.15]">
             Bajo mantenimiento
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[40px] h-[40px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[16px] leading-[1.15]">
            Operación simple para residentes
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[40px] h-[40px]" loading="lazy" />
            </div>
          </div>
          <p class="font-[500] text-black text-[16px] leading-[1.15]">
            Valor agregado para el edificio
          </p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const statsSection = document.querySelector(".servicio-estadisticas");
    const counters = document.querySelectorAll("[data-counter]");
    let hasAnimated = false;

    const animateCounters = () => {
      if (hasAnimated) return;
      hasAnimated = true;

      counters.forEach((counterEl) => {
        const target = Number(counterEl.getAttribute("data-target") ?? "0");
        const prefix = counterEl.getAttribute("data-prefix") ?? "";
        const suffix = counterEl.getAttribute("data-suffix") ?? "";

        let current = 0;
        const duration = 1300;
        const start = performance.now();

        const step = (timestamp) => {
          const progress = Math.min((timestamp - start) / duration, 1);
          current = Math.floor(progress * target);
          counterEl.textContent = `${prefix}${current}${suffix}`;

          if (progress < 1) {
            requestAnimationFrame(step);
          } else {
            counterEl.textContent = `${prefix}${target}${suffix}`;
          }
        };

        requestAnimationFrame(step);
      });
    };

    if (statsSection) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              animateCounters();
              observer.disconnect();
            }
          });
        },
        { threshold: 0.3 },
      );

      observer.observe(statsSection);
    }
  </script>
</Layout>

<style>
  .servicio-banner__overlay {
    background: linear-gradient(
      90deg,
      rgb(18 38 64 / 0.95) 0%,
      rgb(18 38 64 / 0.82) 40%,
      rgb(18 38 64 / 0.55) 70%,
      rgb(18 38 64 / 0.25) 100%
    );
  }
</style>
