---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getImage } from '@/lib/getImage';
import { getContentSlug } from '@/lib/content-entries';

export async function getStaticPaths() {
  const entries = await getCollection('soluciones', ({ data }) => data.published);
  return entries.map((solucion: CollectionEntry<'soluciones'>) => ({
    params: { slug: getContentSlug(solucion.id) },
    props: { solucion },
  }));
}

interface Props {
  solucion: CollectionEntry<'soluciones'>;
}

const { solucion } = Astro.props as Props;
const { data } = solucion;
const heroImage = await getImage(data.heroImage);
---

<Layout title={`${data.heroTitle} - CDC Equipos`} description={data.description}>
  <section class="relative pt-4 md:pt-6">
    <div class="relative h-[480px] md:h-[540px] overflow-hidden">
      {
        heroImage ? (
          <Image
            src={heroImage}
            alt={data.heroImageAlt ?? data.heroTitle}
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
          />
        ) : (
          <div class="absolute inset-0 bg-[#0b2e4f]" />
        )
      }
      <div class="absolute inset-0 bg-gradient-to-t from-[#0b2e4f]/95 via-[#0b2e4f]/60 to-transparent" />

      <div class="relative z-10 h-full flex items-end pb-16">
        <div class="max-w-7xl mx-auto px-4 lg:px-8 w-full">
          <div class="max-w-3xl">
            <div class="inline-block px-3 py-1 rounded-full bg-[#1f6fbe] text-white text-xs font-semibold mb-5 uppercase tracking-wide">
              {data.badge}
            </div>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight mb-5 text-white">
              {data.heroTitle}
            </h1>
            <p class="text-white/80 text-base sm:text-lg leading-relaxed mb-8 max-w-xl">
              {data.heroDescription}
            </p>
            <a
              href={data.ctaHref}
              class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-white text-[#0b2e4f] font-semibold text-sm hover:bg-white/90 transition-colors"
            >
              Solicitar asesoría
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white border-b border-[#e2e8f0]">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-0">
        {
          data.stats.map((stat, index) => (
            <div
              class:list={[
                'py-8 md:py-10 text-center',
                index < data.stats.length - 1 && 'border-r border-[#e2e8f0]',
              ]}
            >
              <div class="text-3xl md:text-4xl font-extrabold text-[#1f6fbe] mb-1">{stat.value}</div>
              <div class="text-xs md:text-sm text-[#64748b] font-medium">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-[#f4f4f4]">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-extrabold mb-10 text-center text-[#1b1e4b]">
        {data.challengesTitle}
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
        {
          data.challenges.map((challenge) => (
            <div class="flex items-start gap-3 p-5 rounded-lg bg-white border border-[#e2e8f0] hover:border-[#1f6fbe]/30 hover:shadow-md transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#1f6fbe] mt-0.5 shrink-0" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="m9 12 2 2 4-4"></path>
              </svg>
              <span class="text-sm font-medium text-[#111827]">{challenge}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-extrabold mb-4 text-center text-[#1b1e4b]">
        {data.solutionTitle}
      </h2>
      {
        data.solutionIntro && (
          <p class="text-[#64748b] text-center max-w-2xl mx-auto mb-12">
            {data.solutionIntro}
          </p>
        )
      }
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {
          data.solutionItems.map((item) => (
            <div class="p-6 rounded-xl border border-[#e2e8f0] bg-white hover:border-[#1f6fbe]/30 hover:shadow-md transition-all">
              <h3 class="text-base font-bold mb-2 text-[#111827]">{item.title}</h3>
              <p class="text-sm text-[#64748b] leading-relaxed">{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-[#f4f4f4]">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-extrabold mb-10 text-center text-[#1b1e4b]">
        {data.benefitsTitle}
      </h2>
      <div class="flex flex-wrap justify-center gap-4 max-w-3xl mx-auto">
        {
          data.benefits.map((benefit) => (
            <div class="flex items-center gap-2 px-5 py-3 rounded-full bg-[#1f6fbe]/10 border border-[#1f6fbe]/20 hover:bg-[#1f6fbe]/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#1f6fbe] shrink-0" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="m9 12 2 2 4-4"></path>
              </svg>
              <span class="text-sm font-semibold text-[#111827]">{benefit}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="contacto-sector" class="py-20 md:py-28 bg-[#0b2e4f] text-white">
    <div class="max-w-7xl mx-auto px-4 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold mb-6">
        {data.ctaTitle}
      </h2>
      <a
        href={data.ctaHref}
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-md bg-[#1f6fbe] text-white font-semibold text-sm hover:bg-[#185fa8] transition-colors"
      >
        {data.ctaButtonText}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </section>
</Layout>
