---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { getContentSlug } from '@/lib/content-entries';

const soluciones = (await getCollection('soluciones', ({ data }) => data.published)).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
---

<Layout
  title="Soluciones por sector - CDC Equipos"
  description="Soluciones de lavandería industrial adaptadas a cada rubro: hoteles, clínicas, lavanderías comerciales y más."
>
  <section class="bg-[#0b2e4f] text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 lg:px-8 text-center">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4">Soluciones por sector</h1>
      <p class="text-white/80 max-w-2xl mx-auto text-base md:text-lg">
        Diseñamos propuestas técnicas adaptadas a las necesidades de cada industria.
      </p>
    </div>
  </section>

  <section class="py-14 md:py-20 bg-[#f4f4f4]">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          soluciones.map((solucion) => (
            <article class="bg-white rounded-[14px] border border-[#e5e7eb] shadow-sm p-6 hover:border-[#1f6fbe]/30 hover:shadow-md transition-all">
              <div class="inline-block px-3 py-1 rounded-full bg-[#1f6fbe]/10 text-[#1f6fbe] text-xs font-semibold mb-4 uppercase tracking-wide">
                {solucion.data.badge}
              </div>
              <h2 class="text-[#111827] text-lg font-bold leading-tight">{solucion.data.title}</h2>
              <p class="mt-3 text-[#4b5563] text-sm leading-relaxed">{solucion.data.description}</p>
              <a
                href={`/soluciones/${getContentSlug(solucion.id)}`}
                class="mt-5 inline-flex items-center gap-2 text-[#000] font-medium text-sm transition-colors duration-300 hover:text-[#1f6fbe]"
              >
                Explorar
                <span aria-hidden="true">→</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
